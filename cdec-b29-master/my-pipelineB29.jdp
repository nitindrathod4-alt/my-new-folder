stage('BUILD STAGE') {
    steps {
        dir('cdec-b29-master/backend') {
            sh '''
                export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
                export PATH=$JAVA_HOME/bin:$PATH

                java -version
                javac -version

                mvn clean package -DskipTests
            '''
        }
        echo 'Build Success'
    }
}
